---
interface Props {
  title: string;
  date: string;
  excerpt: string;
  tags?: string[];
  slug: string;
  image?: string;
}

const { title, date, excerpt, tags = [], slug, image } = Astro.props;
---

<article class="py-8">
  {image && (
    <a href={`/projects/${slug}`} class="block mb-4 overflow-hidden rounded-lg">
      <img src={image} alt={title} class="w-full h-auto object-cover" loading="lazy" />
    </a>
  )}
  <div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline gap-1">
    <a href={`/projects/${slug}`} class="text-lg font-medium text-primary hover:text-interactive transition-colors">
      {title}
    </a>
    <time class="text-sm text-secondary">{date}</time>
  </div>
  <p class="mt-2 text-base text-primary leading-relaxed">{excerpt}</p>
  {tags.length > 0 && (
    <div class="mt-2 flex gap-2">
      {tags.map(tag => (
        <span class="text-sm text-secondary">{tag}</span>
      ))}
    </div>
  )}
</article>

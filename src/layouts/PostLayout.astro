---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: string;
  tags?: string[];
  description?: string;
  image?: string;
  url?: string;
}

const { title, date, tags = [], description, image, url } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="mx-auto max-w-[80ch] px-6 py-16">
    {image && (
      <img src={image} alt={title} class="w-full h-auto rounded-lg mb-8" />
    )}
    <header class="mb-8">
      <h1 class="text-4xl font-bold text-primary mb-2">{title}</h1>
      <div class="flex items-center gap-3">
        <time class="text-sm text-secondary">{date}</time>
        {tags.length > 0 && (
          <span class="text-sm text-secondary">· {tags.join(', ')}</span>
        )}
        {url && (
          <a href={url} target="_blank" rel="noopener noreferrer" class="text-sm text-primary hover:text-interactive transition-colors underline underline-offset-2">View a Project →</a>
        )}
      </div>
    </header>
    <div class="text-base leading-[1.7] text-primary space-y-4 [&_h2]:text-xl [&_h2]:font-semibold [&_h2]:text-primary [&_h2]:pt-4 [&_h2]:pb-1 [&_h3]:font-medium [&_h3]:text-primary [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:space-y-1 [&_li]:text-primary [&_a]:text-primary [&_a]:hover:text-interactive [&_a]:transition-colors [&_a]:underline [&_a]:underline-offset-2 [&_a]:decoration-border [&_p]:text-secondary">
      <slot />
    </div>
  </article>
</BaseLayout>

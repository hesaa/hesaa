---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectListItem from '../../components/ProjectListItem.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
);
---

<BaseLayout title="Projects - Hesaa">
  <div class="mx-auto max-w-[80ch] px-6 py-16">
    <h1 class="text-4xl font-bold text-primary mb-8">Projects</h1>
    <div>
      {projects.map(project => (
        <ProjectListItem
          title={project.data.title}
          date={project.data.date}
          excerpt={project.data.excerpt}
          tags={project.data.tags}
          slug={project.id}
          image={project.data.image}
        />
      ))}
    </div>
  </div>
</BaseLayout>

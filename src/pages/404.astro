---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Not Found">
  <div class="mx-auto max-w-[80ch] px-6 py-16">
    <h1 class="text-4xl font-bold text-primary mb-4">404</h1>
    <p class="text-base text-primary">This page doesn't exist.</p>
    <a href="/" class="inline-block mt-4 text-base text-primary hover:text-interactive transition-colors">
      ← Back home
    </a>
  </div>
</BaseLayout>
